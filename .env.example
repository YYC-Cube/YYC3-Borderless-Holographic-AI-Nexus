# ============================================================
# YYC³ Borderless Holographic AI Nexus — Environment Variables
# ============================================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# --- Vite ---
# VITE_ 前缀的变量会暴露给客户端代码
VITE_APP_TITLE=YYC³ AI Assistant
VITE_APP_VERSION=7.4.0

# --- Supabase (可选) ---
# 如需启用云同步功能，请填写以下配置
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Playwright E2E ---
# PLAYWRIGHT_BASE_URL=http://localhost:5173